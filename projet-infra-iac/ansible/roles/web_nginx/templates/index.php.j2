<?php
// =============================================================================
// WebApp - Projet Virtualisation M1
// Demo cluster web HA avec persistence PostgreSQL
// Servi par : {{ ansible_hostname }} ({{ ansible_default_ipv4.address | default('?') }})
// =============================================================================

// Connexion BDD
$dbHost = "{{ db_host }}";
$dbPort = "{{ db_port }}";
$dbName = "{{ db_name }}";
$dbUser = "{{ db_user }}";
$dbPass = "{{ db_password }}";

// Identification du serveur backend
$serverName = "{{ ansible_hostname }}";
$serverIp   = "{{ ansible_default_ipv4.address | default('?') }}";

$message = "";
$messageType = "info";

try {
    $dsn = "pgsql:host={$dbHost};port={$dbPort};dbname={$dbName}";
    $pdo = new PDO($dsn, $dbUser, $dbPass, [
        PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
        PDO::ATTR_TIMEOUT => 5,
    ]);

    // Creer la table si elle n'existe pas
    $pdo->exec("
        CREATE TABLE IF NOT EXISTS messages (
            id SERIAL PRIMARY KEY,
            author VARCHAR(100) NOT NULL,
            content TEXT NOT NULL,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            served_by VARCHAR(100)
        )
    ");

    // Traitement du formulaire
    if ($_SERVER['REQUEST_METHOD'] === 'POST') {
        $author = trim($_POST['author'] ?? '');
        $content = trim($_POST['content'] ?? '');

        if (!empty($author) && !empty($content)) {
            $stmt = $pdo->prepare("
                INSERT INTO messages (author, content, served_by)
                VALUES (:author, :content, :served_by)
            ");
            $stmt->execute([
                ':author'    => $author,
                ':content'   => $content,
                ':served_by' => $serverName,
            ]);
            $message = "Message ajoute avec succes par {$serverName} !";
            $messageType = "success";
        } else {
            $message = "Auteur et contenu sont requis";
            $messageType = "error";
        }
    }

    // Recuperer les 10 derniers messages
    $stmt = $pdo->query("
        SELECT id, author, content, created_at, served_by
        FROM messages
        ORDER BY created_at DESC
        LIMIT 10
    ");
    $messages = $stmt->fetchAll(PDO::FETCH_ASSOC);

    // Compter le total
    $totalStmt = $pdo->query("SELECT COUNT(*) as total FROM messages");
    $total = $totalStmt->fetch(PDO::FETCH_ASSOC)['total'];

    $dbStatus = "OK (PostgreSQL connecte)";
    $dbStatusClass = "ok";

} catch (PDOException $e) {
    $dbStatus = "ERREUR : " . $e->getMessage();
    $dbStatusClass = "error";
    $messages = [];
    $total = 0;
}
